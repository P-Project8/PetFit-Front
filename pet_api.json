{
  "baseResponse": {
    "timestamp": "string (ISO datetime)",
    "code": "string",
    "message": "string",
    "result": "T"
  },

  "schemas": {
    "PetResponse": {
      "id": "number",
      "name": "string",
      "breed": "string",
      "age": "number",
      "weight": "number (kg)",
      "neckSize": "number (cm)",
      "chestSize": "number (cm)",
      "backLength": "number (cm)",
      "imageUrl": "string",
      "createdAt": "string (ISO datetime)",
      "updatedAt": "string (ISO datetime)"
    },
    "CreatePetRequest": {
      "name": "string (required)",
      "breed": "string (required)",
      "age": "number",
      "weight": "number",
      "neckSize": "number",
      "chestSize": "number",
      "backLength": "number",
      "imageUrl": "string"
    },
    "UpdatePetRequest": {
      "note": "변경할 필드만 전송",
      "name": "string?",
      "breed": "string?",
      "age": "number?",
      "weight": "number?",
      "neckSize": "number?",
      "chestSize": "number?",
      "backLength": "number?",
      "imageUrl": "string?"
    },
    "SizeRecommendationResponse": {
      "petId": "number",
      "petName": "string",
      "productId": "number",
      "productName": "string",
      "recommendedSize": "string",
      "reasoning": "string",
      "optionFits": [
        {
          "size": "string",
          "fit": "string",
          "description": "string"
        }
      ]
    },
    "SimilarPetCurationResponse": {
      "petId": "number",
      "petName": "string",
      "chestSize": "number (cm)",
      "similarUserCount": "number",
      "products": [
        {
          "productId": "number",
          "name": "string",
          "price": "number",
          "thumbnailUrl": "string",
          "orderCount": "number",
          "popularityPercent": "number"
        }
      ]
    },
    "FileUploadResponse": {
      "fileUrl": "string (S3 URL)",
      "folder": "string",
      "fileSize": "number (bytes)",
      "contentType": "string (MIME type)"
    }
  },

  "paths": {
    "GET /api/pets": {
      "summary": "내 반려견 목록 조회",
      "auth": true,
      "response": "PetResponse[]"
    },
    "POST /api/pets": {
      "summary": "반려견 등록 (최대 5마리)",
      "auth": true,
      "requestBody": "CreatePetRequest",
      "response": "PetResponse",
      "errors": {
        "400": "입력값 오류 또는 5마리 초과",
        "401": "인증 필요"
      }
    },
    "GET /api/pets/{petId}": {
      "summary": "반려견 상세 조회",
      "auth": true,
      "params": { "petId": "number (path)" },
      "response": "PetResponse",
      "errors": {
        "403": "본인 반려견이 아님",
        "404": "반려견을 찾을 수 없음"
      }
    },
    "PATCH /api/pets/{petId}": {
      "summary": "반려견 정보 수정",
      "auth": true,
      "params": { "petId": "number (path)" },
      "requestBody": "UpdatePetRequest",
      "response": "PetResponse"
    },
    "DELETE /api/pets/{petId}": {
      "summary": "반려견 삭제 (soft delete)",
      "auth": true,
      "params": { "petId": "number (path)" },
      "response": "string (null)"
    },
    "GET /api/pets/{petId}/size-recommendation": {
      "summary": "사이즈 추천",
      "description": "반려견 chestSize 기반으로 특정 상품의 최적 사이즈 추천",
      "auth": true,
      "params": {
        "petId": "number (path)",
        "productId": "number (query, required)"
      },
      "response": "SizeRecommendationResponse",
      "errors": {
        "400": "추천 가능한 사이즈 옵션 없음",
        "404": "반려견 또는 상품을 찾을 수 없음"
      }
    },
    "GET /api/pets/{petId}/similar-products": {
      "summary": "유사 체형 큐레이션",
      "description": "chestSize ±20% 범위 사용자들이 많이 구매한 상품 TOP 10",
      "auth": true,
      "params": { "petId": "number (path)" },
      "response": "SimilarPetCurationResponse",
      "errors": {
        "404": "반려견을 찾을 수 없음"
      }
    },
    "POST /api/files/upload": {
      "summary": "이미지 업로드 (S3)",
      "description": "S3에 이미지를 업로드합니다. folder 파라미터로 저장 폴더 지정",
      "auth": true,
      "params": {
        "folder": "string (query, required) — pets | gallery | reviews | styling | etc"
      },
      "requestBody": "multipart/form-data — file: binary",
      "response": "FileUploadResponse"
    },
    "DELETE /api/files": {
      "summary": "이미지 삭제 (S3)",
      "auth": true,
      "params": {
        "fileUrl": "string (query, required) — 삭제할 파일의 S3 URL"
      },
      "response": "string (null)"
    }
  }
}
